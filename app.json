        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.shreyasv.calculator",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "538d422e-22ba-4f67-b9ab-2c4d702022f2"
      }
    },
    "owner": "ishreyasvs-organization"
